<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="hr.algebra.hotel.controller.ReviewController">

    <top>
        <VBox spacing="10">
            <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
            <Label fx:id="hotelNameLabel" text="Reviews" style="-fx-font-size: 16; -fx-font-weight: bold;"/>
        </VBox>
    </top>

    <center>
        <TableView fx:id="reviewTable" onMouseClicked="#handleTableClick">
            <columns>
                <TableColumn fx:id="usernameColumn" text="User" prefWidth="150"/>
                <TableColumn fx:id="ratingColumn" text="Rating" prefWidth="80"/>
                <TableColumn fx:id="commentColumn" text="Comment" prefWidth="300"/>
                <TableColumn fx:id="dateColumn" text="Date" prefWidth="150"/>
            </columns>
        </TableView>
    </center>

    <right>
        <VBox spacing="10" prefWidth="250">
            <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>

            <Label text="Review Details" style="-fx-font-weight: bold;"/>

            <ComboBox fx:id="ratingCombo" promptText="Rating (1-5)" maxWidth="Infinity"/>
            <TextArea fx:id="commentField" promptText="Comment" prefHeight="100"/>

            <Label fx:id="statusLabel" text=""/>

            <HBox spacing="10">
                <Button text="Add" onAction="#handleAdd" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                <Button text="Update" onAction="#handleUpdate" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                <Button text="Delete" onAction="#handleDelete" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            </HBox>
        </VBox>
    </right>

</BorderPane>
