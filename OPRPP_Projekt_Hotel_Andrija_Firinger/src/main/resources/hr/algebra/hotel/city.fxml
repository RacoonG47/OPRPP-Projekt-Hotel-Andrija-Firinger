<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="hr.algebra.hotel.controller.CityController">

    <top>
        <VBox spacing="10">
            <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
            <Label text="Cities" style="-fx-font-size: 16; -fx-font-weight: bold;"/>
        </VBox>
    </top>

    <center>
        <TableView fx:id="cityTable" onMouseClicked="#handleTableClick">
            <columns>
                <TableColumn fx:id="nameColumn" text="Name" prefWidth="250"/>
                <TableColumn fx:id="countryColumn" text="Country" prefWidth="250"/>
            </columns>
        </TableView>
    </center>

    <right>
        <VBox spacing="10" prefWidth="250">
            <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>

            <Label text="City Details" style="-fx-font-weight: bold;"/>

            <TextField fx:id="nameField" promptText="City name"/>
            <TextField fx:id="countryField" promptText="Country"/>

            <Label fx:id="statusLabel" text=""/>

            <HBox spacing="10">
                <Button text="Add" onAction="#handleAdd" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                <Button text="Update" onAction="#handleUpdate" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                <Button text="Delete" onAction="#handleDelete" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            </HBox>
        </VBox>
    </right>

</BorderPane>
